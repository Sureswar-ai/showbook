# ============================================================
# ShowBook env — copy to .env (or leave these defaults as-is)
# ============================================================
#
# Zero-install demo build: SQLite + in-memory Redis. No paid
# services, no cloud signup, no Docker. Just Node.
# ============================================================

# ---- Database ----
# Prisma SQLite: file path is relative to packages/db/prisma/
DATABASE_URL="file:./dev.db"

# ---- Redis ----
# Leave empty to use the in-process in-memory adapter (recommended for demo).
# To point at a real Redis server (Upstash rediss://… or self-hosted), paste the URL here.
REDIS_URL=""

# ---- Auth ----
JWT_SECRET="dev-jwt-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ---- API ----
API_PORT=3001
API_CORS_ORIGIN="http://localhost:3000"

# ---- Demo / dev flags ----
# When true, OTPs are returned in response bodies + logged to stdout.
DEMO_MODE=true
# Always-accepted OTP when DEMO_MODE=true. Real OTP is still generated & logged.
DEMO_OTP_BYPASS="123456"

# ---- Frontend (public) ----
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_DEMO_MODE=true
